//@version=5
strategy("配对交易: AAPL vs WMT", overlay=false, default_qty_type=strategy.percent_of_equity, default_qty_value=50)

// 输入参数
symbol2 = input.symbol("NASDAQ:WMT", "第二标的")
lookback = input.int(20, "回看周期", minval=5)
entry_threshold = input.float(2.0, "入场Z分数阈值", minval=0.5, step=0.1)
exit_threshold = input.float(0.5, "出场Z分数阈值", minval=0.1, step=0.1)

// 获取第二标的数据
price2 = request.security(symbol2, timeframe.period, close)

// 计算价差（比率法）
spread = close / price2

// 计算价差的Z分数
spread_ma = ta.sma(spread, lookback)
spread_std = ta.stdev(spread, lookback)
zscore = (spread - spread_ma) / spread_std

// 绘制价差和Z分数
plot(zscore, "Z分数", color=color.blue, linewidth=2)
hline(entry_threshold, "上入场线", color=color.red, linestyle=hline.style_dashed)
hline(-entry_threshold, "下入场线", color=color.green, linestyle=hline.style_dashed)
hline(exit_threshold, "上出场线", color=color.orange, linestyle=hline.style_dotted)
hline(-exit_threshold, "下出场线", color=color.orange, linestyle=hline.style_dotted)
hline(0, "均值", color=color.gray)

// 交易逻辑
// 当Z分数高时：做空AAPL（表现过好），做多WMT（表现不足）
if zscore > entry_threshold and strategy.position_size == 0
    strategy.entry("做空AAPL", strategy.short)
    alert("配对交易: 做空AAPL, 做多WMT", alert.freq_once_per_bar)

// 当Z分数低时：做多AAPL（表现不足），做空WMT（表现过好）
if zscore < -entry_threshold and strategy.position_size == 0
    strategy.entry("做多AAPL", strategy.long)
    alert("配对交易: 做多AAPL, 做空WMT", alert.freq_once_per_bar)

// 出场条件
if strategy.position_size > 0 and zscore > -exit_threshold
    strategy.close("做多AAPL")

if strategy.position_size < 0 and zscore < exit_threshold
    strategy.close("做空AAPL")

/*
═══════════════════════════════════════════════════════════════════════════════
策略核心要点：
═══════════════════════════════════════════════════════════════════════════════

1. 策略类型：统计套利 - 配对交易（Pairs Trading）

2. 核心逻辑：
   - 基于两个相关性强的股票价格比率的均值回归特性
   - 当价格比率偏离历史均值时建仓，回归均值时平仓
   - 使用Z分数标准化偏离程度，避免参数敏感性

3. 入场信号：
   - Z分数 > 2.0：价差过大，做空AAPL（相对强势）做多WMT（相对弱势）
   - Z分数 < -2.0：价差过小，做多AAPL（相对弱势）做空WMT（相对强势）

4. 出场信号：
   - 价差回归至0.5倍标准差内时平仓

5. 风险控制：
   - 市场中性策略，降低系统性风险
   - 适用于相关性高的股票对（如同行业股票）

6. 适用场景：
   - 横盘震荡市场
   - 两个标的存在长期稳定的协整关系
   - 不适合趋势性市场或相关性突然破裂的情况

7. 优化建议：
   - 可以添加协整检验（ADF测试）动态判断配对有效性
   - 考虑动态调整头寸比例以匹配两个标的的波动率
   - 添加最大持仓时间限制避免长期套牢

═══════════════════════════════════════════════════════════════════════════════
*/
