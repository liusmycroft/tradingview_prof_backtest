//@version=6
indicator("多标的波动率监控", overlay=false, format=format.percent, precision=2)

// ═══════════════════════════════════════════════════════════════════════════════
// 配置标的与显示选项
// ═══════════════════════════════════════════════════════════════════════════════
sym1      = input.symbol("AMEX:SPY", "标的1", group="标的")
sym2      = input.symbol("NASDAQ:QQQ", "标的2", group="标的")
sym3      = input.symbol("AMEX:IWM", "标的3", group="标的")

show_hv1  = input.bool(true, "HV 标的1", group="显示", inline="d1")
show_ma1  = input.bool(true, "均值 标的1", group="显示", inline="d1")
show_hv2  = input.bool(true, "HV 标的2", group="显示", inline="d2")
show_ma2  = input.bool(true, "均值 标的2", group="显示", inline="d2")
show_hv3  = input.bool(true, "HV 标的3", group="显示", inline="d3")
show_ma3  = input.bool(true, "均值 标的3", group="显示", inline="d3")

hv_length = input.int(20, "HV周期", minval=5, maxval=100, group="参数")
ma_length = input.int(50, "均值周期", minval=5, maxval=200, group="参数")

// ══════════════════════════════════════
// 波动率计算
// ══════════════════════════════════════
calcHV(src, len) =>
    ta.stdev(src, len) / ta.sma(src, len) * 100

// ══════════════════════════════════════
// 获取数据
// ══════════════════════════════════════
hv1 = request.security(sym1, timeframe.period, calcHV(close, hv_length), ignore_invalid_symbol=true)
hv2 = request.security(sym2, timeframe.period, calcHV(close, hv_length), ignore_invalid_symbol=true)
hv3 = request.security(sym3, timeframe.period, calcHV(close, hv_length), ignore_invalid_symbol=true)

// 每个标的自己的 HV 均值
hvMa1 = ta.sma(hv1, ma_length)
hvMa2 = ta.sma(hv2, ma_length)
hvMa3 = ta.sma(hv3, ma_length)

// 偏离度
hvDev1 = hv1 - hvMa1
hvDev2 = hv2 - hvMa2
hvDev3 = hv3 - hvMa3

// ══════════════════════════════════════
// 颜色
// ══════════════════════════════════════
c1 = color.rgb(41, 98, 255)    // 蓝
c2 = color.rgb(255, 152, 0)    // 橙
c3 = color.rgb(0, 230, 118)    // 绿

// ══════════════════════════════════════
// 绘制 HV 曲线（实线）
// ══════════════════════════════════════
plot(show_hv1 ? hv1 : na, "HV1", c1, linewidth=2)
plot(show_hv2 ? hv2 : na, "HV2", c2, linewidth=2)
plot(show_hv3 ? hv3 : na, "HV3", c3, linewidth=2)

// 绘制 HV 均值曲线（虚线效果）
plot(show_ma1 ? hvMa1 : na, "HV1 均值", color.new(c1, 50), linewidth=1, style=plot.style_circles)
plot(show_ma2 ? hvMa2 : na, "HV2 均值", color.new(c2, 50), linewidth=1, style=plot.style_circles)
plot(show_ma3 ? hvMa3 : na, "HV3 均值", color.new(c3, 50), linewidth=1, style=plot.style_circles)

// ══════════════════════════════════════
// 辅助函数
// ══════════════════════════════════════
statusText(dev, ma) =>
    pct = ma > 0 ? math.abs(dev) / ma * 100 : 0.0
    if pct > 50
        "⚠ 极端"
    else if pct > 25
        "↑ 偏高"
    else
        "✓ 正常"

statusColor(dev, ma) =>
    pct = ma > 0 ? math.abs(dev) / ma * 100 : 0.0
    if pct > 50
        color.red
    else if pct > 25
        color.yellow
    else
        color.green

// ══════════════════════════════════════
// Info Table
// ══════════════════════════════════════
if barstate.islast
    var t = table.new(position.top_right, 5, 4, bgcolor=color.new(color.black, 80), border_color=color.new(color.gray, 60), border_width=1)

    table.cell(t, 0, 0, "标的", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 0, "HV%", text_color=color.white, text_size=size.small)
    table.cell(t, 2, 0, "均值%", text_color=color.white, text_size=size.small)
    table.cell(t, 3, 0, "偏离", text_color=color.white, text_size=size.small)
    table.cell(t, 4, 0, "状态", text_color=color.white, text_size=size.small)

    table.cell(t, 0, 1, syminfo.ticker(sym1), text_color=c1, text_size=size.small)
    table.cell(t, 1, 1, str.tostring(hv1, "#.##"), text_color=c1, text_size=size.small)
    table.cell(t, 2, 1, str.tostring(hvMa1, "#.##"), text_color=c1, text_size=size.small)
    devSign1 = hvDev1 >= 0 ? "+" : ""
    table.cell(t, 3, 1, devSign1 + str.tostring(hvDev1, "#.##"), text_color=hvDev1 >= 0 ? color.red : color.green, text_size=size.small)
    table.cell(t, 4, 1, statusText(hvDev1, hvMa1), text_color=statusColor(hvDev1, hvMa1), text_size=size.small)

    table.cell(t, 0, 2, syminfo.ticker(sym2), text_color=c2, text_size=size.small)
    table.cell(t, 1, 2, str.tostring(hv2, "#.##"), text_color=c2, text_size=size.small)
    table.cell(t, 2, 2, str.tostring(hvMa2, "#.##"), text_color=c2, text_size=size.small)
    devSign2 = hvDev2 >= 0 ? "+" : ""
    table.cell(t, 3, 2, devSign2 + str.tostring(hvDev2, "#.##"), text_color=hvDev2 >= 0 ? color.red : color.green, text_size=size.small)
    table.cell(t, 4, 2, statusText(hvDev2, hvMa2), text_color=statusColor(hvDev2, hvMa2), text_size=size.small)

    table.cell(t, 0, 3, syminfo.ticker(sym3), text_color=c3, text_size=size.small)
    table.cell(t, 1, 3, str.tostring(hv3, "#.##"), text_color=c3, text_size=size.small)
    table.cell(t, 2, 3, str.tostring(hvMa3, "#.##"), text_color=c3, text_size=size.small)
    devSign3 = hvDev3 >= 0 ? "+" : ""
    table.cell(t, 3, 3, devSign3 + str.tostring(hvDev3, "#.##"), text_color=hvDev3 >= 0 ? color.red : color.green, text_size=size.small)
    table.cell(t, 4, 3, statusText(hvDev3, hvMa3), text_color=statusColor(hvDev3, hvMa3), text_size=size.small)

// ══════════════════════════════════════
// Alerts
// ══════════════════════════════════════
extreme1 = hvMa1 > 0 and math.abs(hvDev1) / hvMa1 * 100 > 50
extreme2 = hvMa2 > 0 and math.abs(hvDev2) / hvMa2 * 100 > 50
extreme3 = hvMa3 > 0 and math.abs(hvDev3) / hvMa3 * 100 > 50
alertcondition(extreme1 or extreme2 or extreme3, "波动率偏离异常", "有标的波动率偏离自身均值超过50%")
