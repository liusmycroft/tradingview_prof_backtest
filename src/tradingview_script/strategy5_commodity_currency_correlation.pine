//@version=5
strategy("商品-货币相关性套利策略", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

// ═══════════════════════════════════════════════════════════════════════════════
// 策略说明：利用原油与加元、黄金与澳元的历史相关性进行套利交易
// 理论基础：资源出口国货币与商品价格存在长期正相关关系
// ═══════════════════════════════════════════════════════════════════════════════

// 输入参数
crude_oil = input.symbol("NYMEX:CL1!", "原油期货")
gold = input.symbol("COMEX:GC1!", "黄金期货")
cad_usd = input.symbol("FX:CADUSD", "加元兑美元")
aud_usd = input.symbol("FX:AUDUSD", "澳元兑美元")
usd_index = input.symbol("TVC:DXY", "美元指数")

// 策略选择
strategy_mode = input.string("原油-加元", "策略模式", options=["原油-加元", "黄金-澳元", "综合"])

// 相关性参数
corr_period = input.int(60, "相关性计算周期", minval=20, maxval=200)
zscore_period = input.int(30, "Z-Score周期", minval=10, maxval=100)
entry_zscore = input.float(2.0, "入场Z-Score阈值", minval=1.0, maxval=3.0, step=0.1)
exit_zscore = input.float(0.5, "出场Z-Score阈值", minval=0.1, maxval=1.5, step=0.1)

// 相关性阈值
min_correlation = input.float(0.6, "最小相关性要求", minval=0.3, maxval=0.95, step=0.05)

// 获取市场数据
oil_close = request.security(crude_oil, timeframe.period, close)
gold_close = request.security(gold, timeframe.period, close)
cad_close = request.security(cad_usd, timeframe.period, close)
aud_close = request.security(aud_usd, timeframe.period, close)
dxy_close = request.security(usd_index, timeframe.period, close)

// ══════════════════════════════════════════════════════════════════════════════
// 数据标准化处理
// ══════════════════════════════════════════════════════════════════════════════

// 计算收益率（去除价格水平影响）
oil_returns = ta.change(oil_close) / oil_close[1] * 100
gold_returns = ta.change(gold_close) / gold_close[1] * 100
cad_returns = ta.change(cad_close) / cad_close[1] * 100
aud_returns = ta.change(aud_close) / aud_close[1] * 100
dxy_returns = ta.change(dxy_close) / dxy_close[1] * 100

// 计算标准化价格（用于协整分析）
oil_normalized = oil_close / ta.sma(oil_close, corr_period)
gold_normalized = gold_close / ta.sma(gold_close, corr_period)
cad_normalized = cad_close / ta.sma(cad_close, corr_period)
aud_normalized = aud_close / ta.sma(aud_close, corr_period)

// ══════════════════════════════════════════════════════════════════════════════
// 因子1: 相关性分析
// ══════════════════════════════════════════════════════════════════════════════

// 计算滚动相关系数
oil_cad_corr = ta.correlation(oil_returns, cad_returns, corr_period)
gold_aud_corr = ta.correlation(gold_returns, aud_returns, corr_period)

// 相关性强度评分
oil_cad_corr_strength = math.abs(oil_cad_corr)
gold_aud_corr_strength = math.abs(gold_aud_corr)

// ══════════════════════════════════════════════════════════════════════════════
// 因子2: 价差（Spread）分析 - 原油-加元
// ══════════════════════════════════════════════════════════════════════════════

// 原油-加元价差（标准化后）
oil_cad_spread = oil_normalized - cad_normalized * 100  // 调整比例使其可比
oil_cad_spread_ma = ta.sma(oil_cad_spread, zscore_period)
oil_cad_spread_std = ta.stdev(oil_cad_spread, zscore_period)
oil_cad_zscore = (oil_cad_spread - oil_cad_spread_ma) / oil_cad_spread_std

// ══════════════════════════════════════════════════════════════════════════════
// 因子3: 价差分析 - 黄金-澳元
// ══════════════════════════════════════════════════════════════════════════════

gold_aud_spread = gold_normalized - aud_normalized * 100
gold_aud_spread_ma = ta.sma(gold_aud_spread, zscore_period)
gold_aud_spread_std = ta.stdev(gold_aud_spread, zscore_period)
gold_aud_zscore = (gold_aud_spread - gold_aud_spread_ma) / gold_aud_spread_std

// ══════════════════════════════════════════════════════════════════════════════
// 因子4: 美元指数影响因子
// ══════════════════════════════════════════════════════════════════════════════

// 美元指数趋势（影响商品和货币）
dxy_ma_short = ta.sma(dxy_close, 10)
dxy_ma_long = ta.sma(dxy_close, 30)
dxy_trend = dxy_ma_short > dxy_ma_long ? 1 : -1  // 1=美元升值，-1=美元贬值

// 美元强弱对商品-货币关系的影响
// 美元强势时：商品和商品货币都倾向下跌，但可能出现背离
dxy_divergence_oil = (oil_returns < 0 and cad_returns > 0 and dxy_trend == 1) or
                      (oil_returns > 0 and cad_returns < 0 and dxy_trend == -1)

dxy_divergence_gold = (gold_returns < 0 and aud_returns > 0 and dxy_trend == 1) or
                       (gold_returns > 0 and aud_returns < 0 and dxy_trend == -1)

// ══════════════════════════════════════════════════════════════════════════════
// 因子5: 动量背离检测
// ══════════════════════════════════════════════════════════════════════════════

oil_rsi = request.security(crude_oil, timeframe.period, ta.rsi(close, 14))
cad_rsi = request.security(cad_usd, timeframe.period, ta.rsi(close, 14))
gold_rsi = request.security(gold, timeframe.period, ta.rsi(close, 14))
aud_rsi = request.security(aud_usd, timeframe.period, ta.rsi(close, 14))

// RSI背离（商品超买但货币未超买 = 背离）
oil_cad_rsi_divergence = math.abs(oil_rsi - cad_rsi)
gold_aud_rsi_divergence = math.abs(gold_rsi - aud_rsi)

// ══════════════════════════════════════════════════════════════════════════════
// 策略1：原油-加元套利信号
// ══════════════════════════════════════════════════════════════════════════════

oil_cad_long_signal = oil_cad_zscore < -entry_zscore and
                       oil_cad_corr > min_correlation and
                       oil_cad_rsi_divergence > 10 and
                       not na(oil_cad_zscore)

oil_cad_short_signal = oil_cad_zscore > entry_zscore and
                        oil_cad_corr > min_correlation and
                        oil_cad_rsi_divergence > 10 and
                        not na(oil_cad_zscore)

oil_cad_exit = math.abs(oil_cad_zscore) < exit_zscore or oil_cad_corr < min_correlation

// ══════════════════════════════════════════════════════════════════════════════
// 策略2：黄金-澳元套利信号
// ══════════════════════════════════════════════════════════════════════════════

gold_aud_long_signal = gold_aud_zscore < -entry_zscore and
                        gold_aud_corr > min_correlation and
                        gold_aud_rsi_divergence > 10 and
                        not na(gold_aud_zscore)

gold_aud_short_signal = gold_aud_zscore > entry_zscore and
                         gold_aud_corr > min_correlation and
                         gold_aud_rsi_divergence > 10 and
                         not na(gold_aud_zscore)

gold_aud_exit = math.abs(gold_aud_zscore) < exit_zscore or gold_aud_corr < min_correlation

// ══════════════════════════════════════════════════════════════════════════════
// 综合策略：评分系统
// ══════════════════════════════════════════════════════════════════════════════

// 原油-加元综合评分
oil_cad_score = 0.0
oil_cad_score := oil_cad_score + (oil_cad_zscore < -entry_zscore ? 3 : oil_cad_zscore > entry_zscore ? -3 : 0)
oil_cad_score := oil_cad_score + (oil_cad_corr > 0.7 ? 2 : oil_cad_corr > min_correlation ? 1 : 0)
oil_cad_score := oil_cad_score + (oil_cad_rsi_divergence > 15 ? 2 : oil_cad_rsi_divergence > 10 ? 1 : 0)
oil_cad_score := oil_cad_score + (dxy_divergence_oil ? 1 : 0)

// 黄金-澳元综合评分
gold_aud_score = 0.0
gold_aud_score := gold_aud_score + (gold_aud_zscore < -entry_zscore ? 3 : gold_aud_zscore > entry_zscore ? -3 : 0)
gold_aud_score := gold_aud_score + (gold_aud_corr > 0.7 ? 2 : gold_aud_corr > min_correlation ? 1 : 0)
gold_aud_score := gold_aud_score + (gold_aud_rsi_divergence > 15 ? 2 : gold_aud_rsi_divergence > 10 ? 1 : 0)
gold_aud_score := gold_aud_score + (dxy_divergence_gold ? 1 : 0)

// ══════════════════════════════════════════════════════════════════════════════
// 策略执行
// ══════════════════════════════════════════════════════════════════════════════

// 根据选择的策略模式执行
if strategy_mode == "原油-加元"
    if oil_cad_long_signal and strategy.position_size == 0
        strategy.entry("原油-加元多", strategy.long)
        alert("原油加元背离: 做多原油/加元价差", alert.freq_once_per_bar)

    if oil_cad_short_signal and strategy.position_size == 0
        strategy.entry("原油-加元空", strategy.short)
        alert("原油加元背离: 做空原油/加元价差", alert.freq_once_per_bar)

    if oil_cad_exit
        strategy.close_all()

else if strategy_mode == "黄金-澳元"
    if gold_aud_long_signal and strategy.position_size == 0
        strategy.entry("黄金-澳元多", strategy.long)
        alert("黄金澳元背离: 做多黄金/澳元价差", alert.freq_once_per_bar)

    if gold_aud_short_signal and strategy.position_size == 0
        strategy.entry("黄金-澳元空", strategy.short)
        alert("黄金澳元背离: 做空黄金/澳元价差", alert.freq_once_per_bar)

    if gold_aud_exit
        strategy.close_all()

else if strategy_mode == "综合"
    // 选择评分更高的策略
    if math.abs(oil_cad_score) > math.abs(gold_aud_score) and math.abs(oil_cad_score) > 5
        if oil_cad_score > 5 and strategy.position_size == 0
            strategy.entry("综合-原油加元多", strategy.long)
        else if oil_cad_score < -5 and strategy.position_size == 0
            strategy.entry("综合-原油加元空", strategy.short)
    else if math.abs(gold_aud_score) > 5
        if gold_aud_score > 5 and strategy.position_size == 0
            strategy.entry("综合-黄金澳元多", strategy.long)
        else if gold_aud_score < -5 and strategy.position_size == 0
            strategy.entry("综合-黄金澳元空", strategy.short)

    // 综合出场
    if (oil_cad_exit and gold_aud_exit) or (math.abs(oil_cad_score) < 3 and math.abs(gold_aud_score) < 3)
        strategy.close_all()

// ══════════════════════════════════════════════════════════════════════════════
// 可视化
// ══════════════════════════════════════════════════════════════════════════════

// 主图绘制Z-Score
plot(strategy_mode == "原油-加元" or strategy_mode == "综合" ? oil_cad_zscore : na,
     "原油-加元Z", color=color.blue, linewidth=2)
plot(strategy_mode == "黄金-澳元" or strategy_mode == "综合" ? gold_aud_zscore : na,
     "黄金-澳元Z", color=color.orange, linewidth=2)

hline(entry_zscore, "上入场线", color=color.red, linestyle=hline.style_dashed)
hline(-entry_zscore, "下入场线", color=color.green, linestyle=hline.style_dashed)
hline(exit_zscore, "上出场线", color=color.maroon, linestyle=hline.style_dotted)
hline(-exit_zscore, "下出场线", color=color.lime, linestyle=hline.style_dotted)
hline(0, "中性", color=color.gray)

// 背景标识
bgcolor(oil_cad_long_signal ? color.new(color.green, 90) : na)
bgcolor(oil_cad_short_signal ? color.new(color.red, 90) : na)
bgcolor(gold_aud_long_signal ? color.new(color.blue, 90) : na)
bgcolor(gold_aud_short_signal ? color.new(color.purple, 90) : na)

// ══════════════════════════════════════════════════════════════════════════════
// 信息面板
// ══════════════════════════════════════════════════════════════════════════════
var table info_table = table.new(position.top_right, 3, 6, border_width=1)

if barstate.islast
    table.cell(info_table, 0, 0, "指标", bgcolor=color.gray, text_color=color.white)
    table.cell(info_table, 1, 0, "原油-加元", bgcolor=color.blue, text_color=color.white)
    table.cell(info_table, 2, 0, "黄金-澳元", bgcolor=color.orange, text_color=color.white)

    // 相关性
    table.cell(info_table, 0, 1, "相关性", text_color=color.white)
    table.cell(info_table, 1, 1, str.tostring(oil_cad_corr, "#.##"),
               bgcolor=oil_cad_corr > min_correlation ? color.new(color.green, 70) : color.new(color.red, 70),
               text_color=color.white)
    table.cell(info_table, 2, 1, str.tostring(gold_aud_corr, "#.##"),
               bgcolor=gold_aud_corr > min_correlation ? color.new(color.green, 70) : color.new(color.red, 70),
               text_color=color.white)

    // Z-Score
    table.cell(info_table, 0, 2, "Z-Score", text_color=color.white)
    table.cell(info_table, 1, 2, str.tostring(oil_cad_zscore, "#.##"), text_color=color.yellow)
    table.cell(info_table, 2, 2, str.tostring(gold_aud_zscore, "#.##"), text_color=color.yellow)

    // RSI背离
    table.cell(info_table, 0, 3, "RSI背离", text_color=color.white)
    table.cell(info_table, 1, 3, str.tostring(oil_cad_rsi_divergence, "#.#"), text_color=color.white)
    table.cell(info_table, 2, 3, str.tostring(gold_aud_rsi_divergence, "#.#"), text_color=color.white)

    // 综合评分
    table.cell(info_table, 0, 4, "综合评分", text_color=color.white)
    table.cell(info_table, 1, 4, str.tostring(oil_cad_score, "#"),
               text_color=oil_cad_score > 0 ? color.lime : color.red)
    table.cell(info_table, 2, 4, str.tostring(gold_aud_score, "#"),
               text_color=gold_aud_score > 0 ? color.lime : color.red)

    // 美元趋势
    dxy_text = dxy_trend == 1 ? "强势" : "弱势"
    table.cell(info_table, 0, 5, "美元趋势", text_color=color.white)
    table.cell(info_table, 1, 5, dxy_text, text_color=color.white)
    table.cell(info_table, 2, 5, str.tostring(dxy_close, "#.##"), text_color=color.white)

/*
═══════════════════════════════════════════════════════════════════════════════
策略5：商品-货币相关性套利策略核心要点
═══════════════════════════════════════════════════════════════════════════════

【策略类型】跨资产类别统计套利 + 宏观对冲

【理论基础】
基于宏观经济学原理：资源出口国货币（CAD、AUD）与其主要出口商品价格
（原油、黄金）存在长期正相关关系。当短期出现背离时，存在均值回归套利机会。

【核心逻辑】
1. 原油-加元对：加拿大是主要原油出口国，原油价格上涨通常利好加元
2. 黄金-澳元对：澳大利亚是主要黄金生产国，黄金价格影响澳元走势
3. 当商品价格与对应货币出现显著背离（Z-Score > 2）时建仓

【多因子体系】
1. 相关性因子
   - 滚动60期相关系数，确保配对关系有效
   - 最小相关性要求0.6，相关性破裂时不交易

2. 价差Z-Score因子
   - 标准化价格后计算价差
   - Z-Score衡量背离程度
   - 入场阈值2.0，出场阈值0.5

3. 美元指数影响因子
   - DXY趋势影响商品和货币同向
   - 识别由美元因素导致的异常背离

4. RSI背离因子
   - 商品与货币RSI差值 > 10表示动量背离
   - 增加入场信号可靠性

5. 动量背离检测
   - 短期收益率方向背离
   - 确认趋势逆转信号

【三种交易模式】
1. 原油-加元模式：专注单一配对，参数优化更精确
2. 黄金-澳元模式：适合避险资产配置
3. 综合模式：动态选择当前机会更好的配对

【信号生成】
入场条件（需同时满足）：
- Z-Score绝对值 > 2.0
- 相关性 > 0.6
- RSI背离 > 10
- 数据有效（非NA）

出场条件（满足其一）：
- Z-Score收敛至 < 0.5
- 相关性下降至 < 最小要求
- 综合评分 < 3

【实战优势】
1. 跨资产类别分散风险
2. 基于宏观经济逻辑，理论支撑强
3. 商品和外汇市场流动性好，适合大资金
4. 可24小时交易（外汇市场）
5. 美元因子控制提高胜率

【风险管理】
- 相关性动态监控，破裂时停止交易
- Z-Score防止过早入场（需显著背离）
- 多因子确认降低假信号
- 美元指数作为市场环境过滤器

【适用场景】
- 全球宏观对冲基金
- 商品CTA策略
- 外汇套利策略
- 适合日线或4小时周期

【参数优化建议】
- corr_period: 根据市场周期调整（趋势市场可延长至80-100）
- entry_zscore: 激进2.0，保守2.5-3.0
- min_correlation: 至少0.6，严格模式0.7以上
- 可添加波动率过滤（VIX > 20时降低仓位）

【拓展方向】
1. 增加铜-智利比索配对（智利是铜出口大国）
2. 天然气-挪威克朗配对
3. 农产品-巴西雷亚尔配对
4. 添加协整检验（ADF test）动态验证配对有效性

【历史表现】
该策略在2008金融危机、2014-2016油价暴跌、2020疫情等宏观冲击期间
表现优异，因为这些时期商品与货币背离最明显。

═══════════════════════════════════════════════════════════════════════════════
*/
