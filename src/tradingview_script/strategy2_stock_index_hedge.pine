//@version=5
strategy("股票多头+指数对冲", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=50)

// 输入参数
index_symbol = input.symbol("CME_MINI:NQ1!", "指数期货标的")
rsi_period = input.int(14, "RSI周期")
rsi_overbought = input.int(70, "RSI超买")
rsi_oversold = input.int(30, "RSI超卖")
ma_fast = input.int(10, "快速均线")
ma_slow = input.int(30, "慢速均线")
hedge_ratio = input.float(0.8, "对冲比例", minval=0.1, maxval=1.0, step=0.1)

// 获取指数数据
index_close = request.security(index_symbol, timeframe.period, close)
index_rsi = request.security(index_symbol, timeframe.period, ta.rsi(close, rsi_period))

// 计算股票指标
stock_rsi = ta.rsi(close, rsi_period)
stock_ma_fast = ta.sma(close, ma_fast)
stock_ma_slow = ta.sma(close, ma_slow)

// 计算Beta（简化相关性）
returns_stock = ta.change(close) / close[1]
returns_index = ta.change(index_close) / index_close[1]
correlation = ta.correlation(returns_stock, returns_index, 50)

// 入场条件
// 股票多头：RSI超卖、快线上穿慢线、且指数未超买
long_condition = ta.crossover(stock_ma_fast, stock_ma_slow) and
                 stock_rsi < rsi_oversold and
                 index_rsi < rsi_overbought

// 股票空头：RSI超买、快线下穿慢线
short_condition = ta.crossunder(stock_ma_fast, stock_ma_slow) and
                  stock_rsi > rsi_overbought

// 出场条件
exit_long = ta.crossunder(stock_ma_fast, stock_ma_slow) or stock_rsi > rsi_overbought
exit_short = ta.crossover(stock_ma_fast, stock_ma_slow) or stock_rsi < rsi_oversold

// 执行交易
if long_condition
    strategy.entry("多头股票", strategy.long)
    alert("做多AAPL + 做空NQ对冲", alert.freq_once_per_bar)

if short_condition
    strategy.entry("空头股票", strategy.short)
    alert("做空AAPL + 做多NQ对冲", alert.freq_once_per_bar)

if exit_long
    strategy.close("多头股票")

if exit_short
    strategy.close("空头股票")

// 绘制指标
plot(stock_ma_fast, "快速均线", color=color.blue)
plot(stock_ma_slow, "慢速均线", color=color.red)
bgcolor(long_condition ? color.new(color.green, 90) : na)
bgcolor(short_condition ? color.new(color.red, 90) : na)

// 显示相关性
var table info_table = table.new(position.top_right, 2, 2)
if barstate.islast
    table.cell(info_table, 0, 0, "相关性:", text_color=color.white)
    table.cell(info_table, 1, 0, str.tostring(correlation, "#.##"), text_color=color.yellow)

/*
═══════════════════════════════════════════════════════════════════════════════
策略核心要点：
═══════════════════════════════════════════════════════════════════════════════

1. 策略类型：多空对冲 - Alpha策略

2. 核心逻辑：
   - 在个股上建立方向性头寸（做多或做空）
   - 同时在相关指数期货上建立反向头寸进行Beta对冲
   - 目标是赚取个股的超额收益（Alpha），规避市场系统性风险（Beta）

3. 多因子入场条件：
   - 技术面：均线金叉/死叉（趋势确认）
   - 超买超卖：RSI指标（反转信号）
   - 市场环境：检查大盘指数状态（避免逆势操作）

4. 对冲机制：
   - 建立股票多头时，理论上应同时在指数期货上建立空头
   - 对冲比例根据股票与指数的Beta值动态调整
   - 本策略简化为固定比例（实际应用需要计算滚动Beta）

5. 风险控制：
   - 相关性监控：当股票与指数相关性过低时应谨慎交易
   - 双重过滤：既看个股信号也看大盘环境
   - 对冲保护：降低市场整体波动对组合的影响

6. 适用场景：
   - 牛市震荡期：做多个股+空头指数对冲
   - 熊市反弹期：选择性做多+保护性对冲
   - 高波动环境：通过对冲降低组合波动率

7. 优化建议：
   - 实时计算滚动Beta值动态调整对冲比例
   - 添加波动率过滤器（VIX等）判断市场状态
   - 考虑交易成本，期货对冲需要频繁调整可能增加成本
   - 可以使用ETF替代期货降低门槛

8. 注意事项：
   - TradingView策略只能在图表标的上执行，对冲部分需手动操作
   - 相关性可能随时间变化，需要定期检验
   - 期货合约有到期日，需注意换月操作

═══════════════════════════════════════════════════════════════════════════════
*/
