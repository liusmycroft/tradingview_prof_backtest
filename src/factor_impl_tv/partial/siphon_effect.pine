//@version=6
// NOTE: 原始因子使用虹吸回流效应，此处用日线资金流入流出近似。
strategy("SIPHON_EFFECT - Capital Siphon vs Reflow", overlay=false,
     fill_orders_on_standard_ohlc=true,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100)

lookback = input.int(20, "Lookback")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.8, "Long Threshold")
short_thresh = input.float(0.2, "Short Threshold")

inflow = close > close[1] ? volume : 0
outflow = close < close[1] ? volume : 0
siphon = ta.sma(outflow, 10) - ta.sma(inflow, 10)
reflow = ta.sma(inflow, 10) - ta.sma(outflow, 10)
diff = reflow - siphon
factor_mean = ta.sma(diff, lookback)
factor_std = ta.stdev(diff, lookback)
factor = (factor_mean + factor_std) / 2

rank = ta.percentrank(factor, rank_len) / 100.0

if barstate.isconfirmed
    if rank > long_thresh
        strategy.entry("Long", strategy.long)
    else if rank < short_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "SiphonEffect", color.new(color.yellow, 0))
plot(rank, "Rank", color.new(color.blue, 0))
