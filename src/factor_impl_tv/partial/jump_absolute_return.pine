//@version=6
// NOTE: 原始因子基于分钟级跳跃检测，此处用日线收益率超过阈值近似跳跃。
strategy("Cumulative Jump Absolute Return (JAR)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)

length = input.int(20, "Factor Length")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.8, "Long Threshold")
short_thresh = input.float(0.2, "Short Threshold")

ret = close / close[1] - 1
threshold = 2 * ta.stdev(ret, 60)
jump_ret = math.abs(ret) > threshold ? math.abs(ret) : 0.0
factor = math.sum(jump_ret, length)

rank = ta.percentrank(factor, rank_len) / 100.0

// High -> volatile -> short
if barstate.isconfirmed
    if rank < short_thresh
        strategy.entry("Long", strategy.long)
    else if rank > long_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "JAR", color=color.new(color.blue, 0))
