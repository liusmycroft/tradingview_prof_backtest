//@version=6
// NOTE: 原始因子基于分钟级数据计算连续同方向K线的成交量占比，此处使用日线近似，用连续同方向日（阳线接阳线或阴线接阴线）的成交量占比代替。
strategy("Consistent Trading Volume (TCV)", overlay=true,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     fill_orders_on_standard_ohlc=true)

// Inputs
length = input.int(20, "SMA Length", minval=5)
rank_len = input.int(120, "Percentile Rank Length", minval=20)
long_thresh = input.float(0.2, "Long Threshold", step=0.05)
short_thresh = input.float(0.8, "Short Threshold", step=0.05)

// Calculations
same_dir = (close > open and close[1] > open[1]) or (close < open and close[1] < open[1])
consist_vol = same_dir ? volume : 0.0
vol_mean = ta.sma(volume, length)
factor = vol_mean > 0 ? ta.sma(consist_vol, length) / vol_mean : 0.0

// Signal
rank = ta.percentrank(factor, rank_len) / 100.0

// Entry/Exit
if barstate.isconfirmed
    if rank < long_thresh
        strategy.entry("Long", strategy.long)
    else if rank > short_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

// Visualization
plot(factor, "TCV Factor", color=color.new(color.orange, 0), display=display.pane)
hline(0.5, "Mid", color=color.gray, display=display.pane)
plot(rank, "Rank", color=color.new(color.blue, 0), display=display.pane)
