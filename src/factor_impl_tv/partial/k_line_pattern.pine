//@version=6
// NOTE: 原始因子使用预计算的K线形态胜率，此处用常见2根K线形态评分近似。
strategy("K-Line Pattern Score (K_LINE_PATTERN)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)

length = input.int(20, "Factor Length")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.8, "Long Threshold")
short_thresh = input.float(0.2, "Short Threshold")

// Bullish engulfing: prev bearish, current bullish wraps prev body
bull_engulf = close[1] < open[1] and close > open and close > open[1] and open < close[1] ? 1.0 : 0.0
// Bearish engulfing: prev bullish, current bearish wraps prev body
bear_engulf = close[1] > open[1] and close < open and close < open[1] and open > close[1] ? -1.0 : 0.0
// Bullish harami: prev bearish, current bullish inside prev body
bull_harami = close[1] < open[1] and close > open and close < open[1] and open > close[1] ? 0.5 : 0.0
// Bearish harami: prev bullish, current bearish inside prev body
bear_harami = close[1] > open[1] and close < open and close > open[1] and open < close[1] ? -0.5 : 0.0
// Hammer: small body at top, long lower shadow
body = math.abs(close - open)
lower_shadow = math.min(close, open) - low
upper_shadow = high - math.max(close, open)
hammer = lower_shadow > 2 * body and upper_shadow < body ? 0.5 : 0.0
// Shooting star: small body at bottom, long upper shadow
shooting = upper_shadow > 2 * body and lower_shadow < body ? -0.5 : 0.0

raw_score = bull_engulf + bear_engulf + bull_harami + bear_harami + hammer + shooting

// Time-decayed sum over lookback
factor = ta.wma(raw_score, length)

rank = ta.percentrank(factor, rank_len) / 100.0

if barstate.isconfirmed
    if rank > long_thresh
        strategy.entry("Long", strategy.long)
    else if rank < short_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "K_LINE_PATTERN", color=color.new(color.blue, 0))
