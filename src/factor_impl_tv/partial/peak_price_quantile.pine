//@version=6
// NOTE: 原始因子使用日内量峰加权价格分位点，此处用日线成交量峰值时的价格位置近似。
strategy("Peak Price Quantile (PEAK_PRICE_QUANTILE)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)
i_T = input.int(20, "Lookback", minval=5)
i_mult = input.float(1.5, "Peak Volume Multiplier", minval=1.0)
peak = volume > i_mult * ta.sma(volume, i_T)
range_high = ta.highest(high, i_T)
range_low = ta.lowest(low, i_T)
peak_pos = peak ? (close - range_low) / (range_high - range_low + 0.0001) : 0.0
factor = ta.sma(peak_pos, i_T)
factor_rank = ta.percentrank(factor, 120) / 100.0
if barstate.isconfirmed
    if factor_rank > 0.8 and strategy.position_size >= 0
        strategy.entry("Short", strategy.short)
    else if factor_rank < 0.2 and strategy.position_size <= 0
        strategy.entry("Long", strategy.long)
plot(factor, "Factor", color=color.new(color.orange, 0), display=display.pane)
