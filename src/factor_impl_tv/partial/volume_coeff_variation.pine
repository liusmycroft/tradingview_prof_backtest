//@version=6
// NOTE: 原始因子使用分钟成交额变异系数，此处用日线成交量CV近似。
strategy("Volume Coeff Variation (VOLUME_COEFF_VARIATION)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)
i_T = input.int(20, "Lookback", minval=5)
factor = ta.stdev(volume, i_T) / (ta.sma(volume, i_T) + 0.0001)
factor_rank = ta.percentrank(factor, 120) / 100.0
if barstate.isconfirmed
    if factor_rank > 0.8 and strategy.position_size >= 0
        strategy.entry("Short", strategy.short)
    else if factor_rank < 0.2 and strategy.position_size <= 0
        strategy.entry("Long", strategy.long)
plot(factor, "Factor", color=color.new(color.orange, 0), display=display.pane)
