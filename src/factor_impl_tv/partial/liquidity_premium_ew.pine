//@version=6
// NOTE: 原始因子使用需求方定价与实际成交差距，此处用日线价差近似流动性溢价。
strategy("Liquidity Premium Equal Weight (LIQUIDITY_PREMIUM_EW)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)

length = input.int(20, "Factor Length")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.8, "Long Threshold")
short_thresh = input.float(0.2, "Short Threshold")

spread = (high - low) / close
factor = ta.sma(spread, length)

rank = ta.percentrank(factor, rank_len) / 100.0

// High -> illiquid -> short
if barstate.isconfirmed
    if rank < short_thresh
        strategy.entry("Long", strategy.long)
    else if rank > long_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "LIQUIDITY_PREMIUM_EW", color=color.new(color.blue, 0))
