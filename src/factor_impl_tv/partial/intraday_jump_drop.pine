//@version=6
// NOTE: 原始因子基于单复利差衡量跳跌度，此处用日线简单收益与对数收益差近似。
strategy("Intraday Jump Drop (INTRADAY_JUMP_DROP)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)

length = input.int(20, "Factor Length")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.8, "Long Threshold")
short_thresh = input.float(0.2, "Short Threshold")

simple_ret = close / close[1] - 1
log_ret = math.log(close / close[1])
factor = ta.sma(math.abs(simple_ret - log_ret), length)

rank = ta.percentrank(factor, rank_len) / 100.0

if barstate.isconfirmed
    if rank > long_thresh
        strategy.entry("Long", strategy.long)
    else if rank < short_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "INTRADAY_JUMP_DROP", color=color.new(color.blue, 0))
