//@version=6
// NOTE: 原始因子使用分钟级数据计算高低价位振幅差异，此处使用日线OHLCV近似，用日振幅在高低价位的条件均值差代替。
strategy("Minute Ideal Amplitude (MINUTE_IDEAL_AMPLITUDE)", overlay=true,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     fill_orders_on_standard_ohlc=true)

// Inputs
length = input.int(20, "Length", minval=5)
rank_len = input.int(120, "Percentile Rank Length", minval=20)
long_thresh = input.float(0.2, "Long Threshold", step=0.05)
short_thresh = input.float(0.8, "Short Threshold", step=0.05)

// Calculations
amp = (high - low) / close[1]
high_p = close > ta.percentile_linear_interpolation(close, length, 75)
low_p = close < ta.percentile_linear_interpolation(close, length, 25)
h_amp = high_p ? amp : 0
l_amp = low_p ? amp : 0
factor = ta.sma(h_amp, length) - ta.sma(l_amp, length)

// Signal
rank = ta.percentrank(factor, rank_len) / 100.0

// Entry/Exit
if barstate.isconfirmed
    if rank < long_thresh
        strategy.entry("Long", strategy.long)
    else if rank > short_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

// Visualization
plot(factor, "MINUTE_IDEAL_AMPLITUDE Factor", color=color.new(color.orange, 0), display=display.pane)
hline(0, "Zero", color=color.gray, display=display.pane)
plot(rank, "Rank", color=color.new(color.blue, 0), display=display.pane)
