//@version=6
// NOTE: 原始因子使用卖出后反弹成交量比率，此处用阴线后阳线成交量近似。
strategy("Post-Sell Rebound Volume Ratio (LCVOL)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)

length = input.int(20, "Factor Length")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.8, "Long Threshold")
short_thresh = input.float(0.2, "Short Threshold")

prev_down = close[1] < open[1]
rebound_vol = prev_down and close > open ? volume : 0.0
factor = ta.sma(rebound_vol, length) / ta.sma(volume, length)

rank = ta.percentrank(factor, rank_len) / 100.0

// High -> strong rebound -> long
if barstate.isconfirmed
    if rank > long_thresh
        strategy.entry("Long", strategy.long)
    else if rank < short_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "LCVOL", color=color.new(color.blue, 0))
