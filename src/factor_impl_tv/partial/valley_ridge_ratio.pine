//@version=6
// NOTE: 原始因子使用日内波谷与波峰成交量加权价格比值，此处用日线近似。
strategy("Valley Ridge Ratio (VALLEY_RIDGE_RATIO)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)
i_T = input.int(20, "Lookback", minval=5)
i_mult = input.float(1.5, "Volume Multiplier", minval=1.0)
peak = volume > i_mult * ta.sma(volume, i_T)
valley = volume < (1.0/i_mult) * ta.sma(volume, i_T)
peak_price = peak ? close : 0.0
valley_price = valley ? close : 0.0
avg_peak = ta.sma(peak_price, i_T)
avg_valley = ta.sma(valley_price, i_T)
factor = avg_valley / (avg_peak + 0.0001)
factor_rank = ta.percentrank(factor, 120) / 100.0
if barstate.isconfirmed
    if factor_rank > 0.8 and strategy.position_size <= 0
        strategy.entry("Long", strategy.long)
    else if factor_rank < 0.2 and strategy.position_size >= 0
        strategy.entry("Short", strategy.short)
plot(factor, "Factor", color=color.new(color.orange, 0), display=display.pane)
