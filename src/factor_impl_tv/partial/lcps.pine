//@version=6
// NOTE: 原始因子使用小单卖出价偏离，此处用阴线收盘价与最低价偏离近似。
strategy("Small Order Sell Price Deviation (LCPS)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)

length = input.int(20, "Factor Length")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.8, "Long Threshold")
short_thresh = input.float(0.2, "Short Threshold")

down_day = close < open
dev = down_day ? (close - low) / close : 0.0
factor = ta.sma(dev, length)

rank = ta.percentrank(factor, rank_len) / 100.0

if barstate.isconfirmed
    if rank > long_thresh
        strategy.entry("Long", strategy.long)
    else if rank < short_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "LCPS", color=color.new(color.blue, 0))
