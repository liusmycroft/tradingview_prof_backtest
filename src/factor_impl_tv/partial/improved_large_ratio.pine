//@version=6
// NOTE: 原始因子使用分钟级大单识别，此处用振幅高低近似大单活跃度。
strategy("Improved Large Order Ratio (IMPROVED_LARGE_RATIO)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)

length = input.int(20, "Factor Length")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.8, "Long Threshold")
short_thresh = input.float(0.2, "Short Threshold")

amp = (high - low) / close
large_bar = amp > ta.sma(amp, length)
large_vol = large_bar ? volume : 0.0
factor = ta.sma(large_vol, length) / ta.sma(volume, length)

rank = ta.percentrank(factor, rank_len) / 100.0

if barstate.isconfirmed
    if rank > long_thresh
        strategy.entry("Long", strategy.long)
    else if rank < short_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "IMPROVED_LARGE_RATIO", color=color.new(color.blue, 0))
