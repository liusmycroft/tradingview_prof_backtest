//@version=6
// NOTE: 原始因子使用最小收益日前一日成交量异常度，此处用前一日成交量与负收益相关性近似。
strategy("Leading Volume Anomaly at Min Return (AMT_MIN)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)

length = input.int(20, "Factor Length")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.8, "Long Threshold")
short_thresh = input.float(0.2, "Short Threshold")

ret = close / close[1] - 1
neg_ret = -ret
factor = ta.correlation(volume[1], neg_ret, length)

rank = ta.percentrank(factor, rank_len) / 100.0

if barstate.isconfirmed
    if rank > long_thresh
        strategy.entry("Long", strategy.long)
    else if rank < short_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "AMT_MIN", color=color.new(color.blue, 0))
