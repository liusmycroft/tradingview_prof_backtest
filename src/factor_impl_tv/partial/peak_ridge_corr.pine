//@version=6
// NOTE: 原始因子使用同时点峰岭数相关性，此处用日线成交量峰谷指标相关性近似。
strategy("Peak Ridge Corr (PEAK_RIDGE_CORR)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)
i_T = input.int(20, "Lookback", minval=5)
i_mult = input.float(1.5, "Peak Multiplier", minval=1.0)
peak = volume > i_mult * ta.sma(volume, i_T) ? 1.0 : 0.0
ridge = volume < (1.0/i_mult) * ta.sma(volume, i_T) ? 1.0 : 0.0
factor = ta.correlation(peak, ridge, i_T)
factor_rank = ta.percentrank(factor, 120) / 100.0
if barstate.isconfirmed
    if factor_rank > 0.8 and strategy.position_size >= 0
        strategy.entry("Short", strategy.short)
    else if factor_rank < 0.2 and strategy.position_size <= 0
        strategy.entry("Long", strategy.long)
plot(factor, "Factor", color=color.new(color.orange, 0), display=display.pane)
