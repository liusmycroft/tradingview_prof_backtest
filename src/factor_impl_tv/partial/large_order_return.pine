//@version=6
// NOTE: 原始因子使用大单推动涨幅，此处用高成交量日收益率近似。
strategy("Large Order Return (LARGE_ORDER_RETURN)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)

length = input.int(20, "Factor Length")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.8, "Long Threshold")
short_thresh = input.float(0.2, "Short Threshold")

high_vol = volume > 1.5 * ta.sma(volume, length)
impact = high_vol ? (close / close[1] - 1) : 0.0
factor = ta.sma(impact, length)

rank = ta.percentrank(factor, rank_len) / 100.0

if barstate.isconfirmed
    if rank > long_thresh
        strategy.entry("Long", strategy.long)
    else if rank < short_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "LARGE_ORDER_RETURN", color=color.new(color.blue, 0))
