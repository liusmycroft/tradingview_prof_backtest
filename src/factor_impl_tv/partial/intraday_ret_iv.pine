//@version=6
// NOTE: 原始因子使用PCA剥离共同成分，此处用基准指数收益近似市场因子。
strategy("Intraday Return Idiosyncratic Volatility (INTRADAY_RET_IV)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)

length = input.int(20, "Factor Length")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.8, "Long Threshold")
short_thresh = input.float(0.2, "Short Threshold")
benchmark = input.symbol("SPY", "Benchmark Symbol")

ret = close / close[1] - 1
bench_close = request.security(benchmark, timeframe.period, close)
mkt_ret = bench_close / bench_close[1] - 1
idio = ret - mkt_ret
factor = ta.stdev(idio, length)

rank = ta.percentrank(factor, rank_len) / 100.0

if barstate.isconfirmed
    if rank > long_thresh
        strategy.entry("Long", strategy.long)
    else if rank < short_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "INTRADAY_RET_IV", color=color.new(color.blue, 0))
