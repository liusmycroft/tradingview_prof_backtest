//@version=6
// NOTE: 原始因子使用行业内市值加权收益率，此处用行业ETF收益率近似。
strategy("Industry Momentum (INDUSTRY_MOMENTUM)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)

length = input.int(20, "Factor Length")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.8, "Long Threshold")
short_thresh = input.float(0.2, "Short Threshold")
sector_sym = input.symbol("SPY", "Sector ETF Symbol")

sector_close = request.security(sector_sym, timeframe.period, close)
sector_ret = sector_close / sector_close[1] - 1
factor = ta.sma(sector_ret, length)

rank = ta.percentrank(factor, rank_len) / 100.0

if barstate.isconfirmed
    if rank > long_thresh
        strategy.entry("Long", strategy.long)
    else if rank < short_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "INDUSTRY_MOMENTUM", color=color.new(color.blue, 0))
