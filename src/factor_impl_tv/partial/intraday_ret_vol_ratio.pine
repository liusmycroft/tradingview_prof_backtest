//@version=6
// NOTE: 原始因子使用分钟级收益率计算夏普比率，此处用日线收益率近似。
strategy("Intraday Return Volatility Ratio (INTRADAY_RET_VOL_RATIO)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)

length = input.int(20, "Factor Length")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.8, "Long Threshold")
short_thresh = input.float(0.2, "Short Threshold")

ret = close / close[1] - 1
vol = ta.stdev(ret, length)
factor = ta.sma(ret, length) / vol

rank = ta.percentrank(factor, rank_len) / 100.0

if barstate.isconfirmed
    if rank > long_thresh
        strategy.entry("Long", strategy.long)
    else if rank < short_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "INTRADAY_RET_VOL_RATIO", color=color.new(color.blue, 0))
