//@version=6
// NOTE: 原始因子使用滞后绝对收益与标准化成交额相关性，此处用日线数据近似。
strategy("Lagged Abs Return Adj Amount Correlation (LAG_ABS_RET_ADJ_AMOUNT_CORR)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)

length = input.int(20, "Factor Length")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.8, "Long Threshold")
short_thresh = input.float(0.2, "Short Threshold")

norm_vol = volume / ta.sma(volume, 60)
lagged_abs_ret = math.abs(close[1] / close[2] - 1)
factor = ta.correlation(lagged_abs_ret, norm_vol, length)

rank = ta.percentrank(factor, rank_len) / 100.0

// High -> short
if barstate.isconfirmed
    if rank < short_thresh
        strategy.entry("Long", strategy.long)
    else if rank > long_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "LAG_ABS_RET_ADJ_AMOUNT_CORR", color=color.new(color.blue, 0))
