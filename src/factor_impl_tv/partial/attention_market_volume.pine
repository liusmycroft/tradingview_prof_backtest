//@version=6
// NOTE: 原始因子基于分钟级数据计算个股收益率对市场成交量变化的敏感度，此处使用日线近似，用指数ETF成交量作为市场成交量代理。
strategy("Attention Market Volume (ATTENTION_MARKET_VOLUME)", overlay=true,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     fill_orders_on_standard_ohlc=true)

// Inputs
mkt_sym = input.symbol("SSE:000300", "Market Benchmark")
corr_len = input.int(60, "Correlation Length", minval=10)
vol_ma_len = input.int(20, "Volume MA Length", minval=5)
rank_len = input.int(120, "Percentile Rank Length", minval=20)
long_thresh = input.float(0.2, "Long Threshold", step=0.05)
short_thresh = input.float(0.8, "Short Threshold", step=0.05)

// Calculations
mkt_close = request.security(mkt_sym, timeframe.period, close)
mkt_volume = request.security(mkt_sym, timeframe.period, volume)
mkt_ret = mkt_close / mkt_close[1] - 1
mkt_vol_ma = ta.sma(mkt_volume, vol_ma_len)
mkt_vol_change = mkt_vol_ma > 0 ? mkt_volume / mkt_vol_ma - 1 : 0.0
daily_ret = close / close[1] - 1
factor = math.abs(ta.correlation(daily_ret, mkt_vol_change, corr_len))

// Signal - High → short
rank = ta.percentrank(factor, rank_len) / 100.0

// Entry/Exit
if barstate.isconfirmed
    if rank < long_thresh
        strategy.entry("Long", strategy.long)
    else if rank > short_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

// Visualization
plot(factor, "ATTENTION_MKT_VOL Factor", color=color.new(color.orange, 0), display=display.pane)
hline(0, "Zero", color=color.gray, display=display.pane)
plot(rank, "Rank", color=color.new(color.blue, 0), display=display.pane)
