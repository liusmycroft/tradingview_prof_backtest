//@version=6
// NOTE: 原始因子使用非分化时刻成交量相关性，此处用低波动时段标准化成交量近似。
strategy("Non-Divergence Volume Correlation (LONE_GOOSE)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)

length = input.int(20, "Factor Length")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.8, "Long Threshold")
short_thresh = input.float(0.2, "Short Threshold")

vol_norm = volume / ta.sma(volume, 60)
ret_abs = math.abs(close / close[1] - 1)
non_div = ret_abs < ta.sma(ret_abs, length) ? vol_norm : 0.0
factor_mean = ta.sma(non_div, length)
factor_std = ta.stdev(non_div, length)
factor = (factor_mean + factor_std) / 2

rank = ta.percentrank(factor, rank_len) / 100.0

if barstate.isconfirmed
    if rank > long_thresh
        strategy.entry("Long", strategy.long)
    else if rank < short_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "LONE_GOOSE", color=color.new(color.blue, 0))
