//@version=6
// NOTE: 原始因子基于分钟级跳跃检测，此处用日线收益率超过阈值近似跳跃频率。
strategy("Jump Arrival (JUMP_ARRIVAL)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)

length = input.int(20, "Factor Length")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.8, "Long Threshold")
short_thresh = input.float(0.2, "Short Threshold")

ret = close / close[1] - 1
threshold = 2 * ta.stdev(ret, 60)
jump = math.abs(ret) > threshold ? 1.0 : 0.0
factor = ta.sma(jump, length)

rank = ta.percentrank(factor, rank_len) / 100.0

// High -> short
if barstate.isconfirmed
    if rank < short_thresh
        strategy.entry("Long", strategy.long)
    else if rank > long_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "JUMP_ARRIVAL", color=color.new(color.blue, 0))
