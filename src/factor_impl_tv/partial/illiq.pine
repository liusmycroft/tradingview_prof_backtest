//@version=6
// NOTE: 原始因子使用分钟级价格冲击计算非流动性，此处用日线振幅与成交额近似。
strategy("Illiquidity (illiq)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)

length = input.int(20, "Factor Length")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.8, "Long Threshold")
short_thresh = input.float(0.2, "Short Threshold")

shortcut = 2 * (high - low) - math.abs(close - open)
value = volume * close
daily_illiq = shortcut / (value / 1e6)
factor = ta.sma(daily_illiq, length)

rank = ta.percentrank(factor, rank_len) / 100.0

// High illiquidity -> short
if barstate.isconfirmed
    if rank < short_thresh
        strategy.entry("Long", strategy.long)
    else if rank > long_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "illiq", color=color.new(color.blue, 0))
