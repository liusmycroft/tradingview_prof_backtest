//@version=6
// NOTE: 原始因子使用EMD分解提取信号与噪声，此处用趋势幅度与日均波动近似。
strategy("Intraday Signal to Noise Ratio (INTRADAY_SNR)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)

length = input.int(20, "Factor Length")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.8, "Long Threshold")
short_thresh = input.float(0.2, "Short Threshold")

signal = math.abs(close - close[length])
noise = ta.sma(math.abs(close / close[1] - 1), length) * length
factor = noise != 0 ? signal / noise : 0.0

rank = ta.percentrank(factor, rank_len) / 100.0

if barstate.isconfirmed
    if rank > long_thresh
        strategy.entry("Long", strategy.long)
    else if rank < short_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "INTRADAY_SNR", color=color.new(color.blue, 0))
