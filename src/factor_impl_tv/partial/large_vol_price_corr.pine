//@version=6
// NOTE: 原始因子使用分钟级大单成交量与价格相关性，此处用日线成交量与收益率相关性近似。
strategy("Large Volume Price Correlation (LARGE_VOL_PRICE_CORR)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)

length = input.int(20, "Factor Length")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.8, "Long Threshold")
short_thresh = input.float(0.2, "Short Threshold")

ret = close / close[1] - 1
factor = ta.correlation(volume, ret, length)

rank = ta.percentrank(factor, rank_len) / 100.0

if barstate.isconfirmed
    if rank > long_thresh
        strategy.entry("Long", strategy.long)
    else if rank < short_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "LARGE_VOL_PRICE_CORR", color=color.new(color.blue, 0))
