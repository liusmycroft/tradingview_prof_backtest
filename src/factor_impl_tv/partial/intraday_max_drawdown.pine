//@version=6
// NOTE: 原始因子使用分钟级最大回撤，此处用日线(high-close)/high近似。
strategy("Intraday Max Drawdown (INTRADAY_MAX_DRAWDOWN)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)

length = input.int(20, "Factor Length")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.8, "Long Threshold")
short_thresh = input.float(0.2, "Short Threshold")

drawdown = (high - close) / high
factor = ta.sma(drawdown, length)

rank = ta.percentrank(factor, rank_len) / 100.0

// High drawdown -> short
if barstate.isconfirmed
    if rank < short_thresh
        strategy.entry("Long", strategy.long)
    else if rank > long_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "INTRADAY_MAX_DRAWDOWN", color=color.new(color.blue, 0))
