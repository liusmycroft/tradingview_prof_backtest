//@version=6
// NOTE: 原始因子基于分钟级跳跃检测，此处用日线收益率超过阈值近似非正跳跃动量。
strategy("Jump Non-Positive Momentum (JUMP_NON_POSITIVE_MOMENTUM)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)

length = input.int(20, "Factor Length")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.8, "Long Threshold")
short_thresh = input.float(0.2, "Short Threshold")

ret = close / close[1] - 1
threshold = 2 * ta.stdev(ret, 60)
non_pos_jump = ret < -threshold ? ret : 0.0
factor = ta.sma(non_pos_jump, length)

rank = ta.percentrank(factor, rank_len) / 100.0

// Very negative -> short
if barstate.isconfirmed
    if rank > long_thresh
        strategy.entry("Long", strategy.long)
    else if rank < short_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "JUMP_NON_POSITIVE_MOMENTUM", color=color.new(color.blue, 0))
