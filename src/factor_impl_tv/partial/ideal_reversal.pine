//@version=6
// NOTE: 原始因子区分大单/小单交易日，此处用成交量高低近似。
strategy("Ideal Reversal (IDEAL_REVERSAL)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)

length = input.int(20, "Factor Length")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.8, "Long Threshold")
short_thresh = input.float(0.2, "Short Threshold")

high_vol_day = volume > ta.sma(volume, length)
daily_ret = close / close[1] - 1
hv_ret = high_vol_day ? daily_ret : 0.0
lv_ret = high_vol_day == false ? daily_ret : 0.0
factor = ta.sma(hv_ret, length) - ta.sma(lv_ret, length)

rank = ta.percentrank(factor, rank_len) / 100.0

if barstate.isconfirmed
    if rank > long_thresh
        strategy.entry("Long", strategy.long)
    else if rank < short_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "IDEAL_REVERSAL", color=color.new(color.blue, 0))
