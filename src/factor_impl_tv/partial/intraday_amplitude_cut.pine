//@version=6
// NOTE: 原始因子使用分钟级振幅切割，此处用日线价格高低区分近似。
strategy("Intraday Amplitude Cut (INTRADAY_AMPLITUDE_CUT)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)

length = input.int(20, "Factor Length")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.8, "Long Threshold")
short_thresh = input.float(0.2, "Short Threshold")

amp = (high - low) / close[1]
high_price = close > ta.sma(close, length)
high_amp = high_price ? amp : 0.0
low_amp = high_price == false ? amp : 0.0
factor = ta.sma(high_amp, length) - ta.sma(low_amp, length)

rank = ta.percentrank(factor, rank_len) / 100.0

if barstate.isconfirmed
    if rank > long_thresh
        strategy.entry("Long", strategy.long)
    else if rank < short_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "INTRADAY_AMPLITUDE_CUT", color=color.new(color.blue, 0))
