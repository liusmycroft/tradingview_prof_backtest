//@version=6
// NOTE: 原始因子通过OLS回归剥离风格因子，此处直接计算换手率波动率近似。
strategy("Idiosyncratic Turnover Volatility (IDIO_TURNOVER_VOL)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)

length = input.int(20, "Factor Length")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.8, "Long Threshold")
short_thresh = input.float(0.2, "Short Threshold")

turnover = volume / ta.sma(volume, 252)
factor = ta.stdev(turnover, length)

rank = ta.percentrank(factor, rank_len) / 100.0

if barstate.isconfirmed
    if rank > long_thresh
        strategy.entry("Long", strategy.long)
    else if rank < short_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "IDIO_TURNOVER_VOL", color=color.new(color.blue, 0))
