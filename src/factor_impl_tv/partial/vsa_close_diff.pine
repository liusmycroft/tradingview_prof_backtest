//@version=6
// NOTE: 原始因子使用成交量支撑区域下限，此处用日线最低价支撑位近似。More negative → more room to fall → short.
strategy("VSA_CLOSE_DIFF - VSA Support Lower Bound vs Close", overlay=false,
     fill_orders_on_standard_ohlc=true,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100)

lookback = input.int(20, "Lookback")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.2, "Long Threshold")
short_thresh = input.float(0.8, "Short Threshold")

support = ta.lowest(low, lookback)
factor = (support - close) / close

rank = ta.percentrank(factor, rank_len) / 100.0

if barstate.isconfirmed
    if rank < long_thresh
        strategy.entry("Long", strategy.long)
    else if rank > short_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "VSA Close Diff", color.new(color.yellow, 0))
plot(rank, "Rank", color.new(color.blue, 0))
