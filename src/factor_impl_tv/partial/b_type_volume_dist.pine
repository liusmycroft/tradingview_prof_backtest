//@version=6
// NOTE: 原始因子基于分钟级数据计算成交量支撑区域与低价区的关系，此处使用日线近似，用20日VWMA相对于价格区间的位置代替。
strategy("B-Type Volume Distribution (B_TYPE_VOLUME_DIST)", overlay=true,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     fill_orders_on_standard_ohlc=true)

// Inputs
length = input.int(20, "Lookback Length", minval=5)
rank_len = input.int(120, "Percentile Rank Length", minval=20)
long_thresh = input.float(0.2, "Long Threshold", step=0.05)
short_thresh = input.float(0.8, "Short Threshold", step=0.05)

// Calculations
vwma_val = ta.vwma(close, length)
lowest_val = ta.lowest(low, length)
highest_val = ta.highest(high, length)
range_size = highest_val - lowest_val
vwap_pos = range_size > 0 ? (vwma_val - lowest_val) / range_size : 0.5
// Low vwap_pos = b-type distribution → long
// Invert: factor = -vwap_pos so low factor → short, high factor → long
factor = -vwap_pos

// Signal
rank = ta.percentrank(factor, rank_len) / 100.0

// Entry/Exit
if barstate.isconfirmed
    if rank < long_thresh
        strategy.entry("Long", strategy.long)
    else if rank > short_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

// Visualization
plot(factor, "B_TYPE_VOL_DIST Factor", color=color.new(color.orange, 0), display=display.pane)
hline(0, "Zero", color=color.gray, display=display.pane)
plot(rank, "Rank", color=color.new(color.blue, 0), display=display.pane)
