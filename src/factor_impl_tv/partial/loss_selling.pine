//@version=6
// NOTE: 原始因子需要换手率加权历史亏损，此处用日线成交量标准化与亏损乘积近似。
strategy("Turnover-Weighted Loss History (LOSS_SELLING)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, fill_orders_on_standard_ohlc=true)

length = input.int(60, "Factor Length")
rank_len = input.int(120, "Rank Length")
long_thresh = input.float(0.8, "Long Threshold")
short_thresh = input.float(0.2, "Short Threshold")

loss = close < close[1] ? math.abs(close / close[1] - 1) : 0.0
turnover = volume / ta.sma(volume, 252)
factor = ta.sma(loss * turnover, length)

rank = ta.percentrank(factor, rank_len) / 100.0

if barstate.isconfirmed
    if rank > long_thresh
        strategy.entry("Long", strategy.long)
    else if rank < short_thresh
        strategy.entry("Short", strategy.short)
    else
        strategy.close_all()

plot(factor, "LOSS_SELLING", color=color.new(color.blue, 0))
