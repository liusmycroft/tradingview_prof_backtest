//@version=6
strategy("Ideal Amplitude (IDEAL_AMPLITUDE)", overlay=true,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100,
     fill_orders_on_standard_ohlc=true)

// ============================================================================
// Inputs
// ============================================================================
i_lookback    = input.int(60, "Lookback Window for Price Quantiles", minval=10)
i_highPct     = input.float(75.0, "High Price Percentile Threshold", minval=50.0, maxval=99.0)
i_lowPct      = input.float(25.0, "Low Price Percentile Threshold", minval=1.0, maxval=50.0)
i_avgLen      = input.int(20, "Amplitude Average Length", minval=1)
i_signalLen   = input.int(20, "Signal MA Length", minval=1)
i_shortThresh = input.float(0.0, "Short Threshold (factor above signal + thresh)", step=0.001)
i_longThresh  = input.float(0.0, "Long Threshold (factor below signal - thresh)", step=0.001)

// ============================================================================
// Calculations
// ============================================================================
amplitude  = high / low - 1.0

high_thresh = ta.percentile_linear_interpolation(close, i_lookback, i_highPct)
low_thresh  = ta.percentile_linear_interpolation(close, i_lookback, i_lowPct)

// Classify current bar and accumulate amplitude averages using var accumulators
var float sum_amp_high  = 0.0
var int   cnt_high      = 0
var float sum_amp_low   = 0.0
var int   cnt_low       = 0

// Use a rolling window approach: track last N bars manually
is_high_price = close >= high_thresh
is_low_price  = close <= low_thresh

// Compute rolling average amplitude for high-price and low-price days
// over the averaging length using a simple loop
avg_amp_high = 0.0
avg_amp_low  = 0.0
count_high   = 0
count_low    = 0

for i = 0 to i_avgLen - 1
    amp_i   = high[i] / low[i] - 1.0
    close_i = close[i]
    ht_i    = ta.percentile_linear_interpolation(close, i_lookback, i_highPct)[i]
    lt_i    = ta.percentile_linear_interpolation(close, i_lookback, i_lowPct)[i]
    if close_i >= ht_i
        avg_amp_high += amp_i
        count_high   += 1
    if close_i <= lt_i
        avg_amp_low += amp_i
        count_low   += 1

avg_amp_high := count_high > 0 ? avg_amp_high / count_high : 0.0
avg_amp_low  := count_low  > 0 ? avg_amp_low  / count_low  : 0.0

// Factor: difference in amplitude between high-price and low-price regimes
factor    = avg_amp_high - avg_amp_low
signal_ma = ta.sma(factor, i_signalLen)

// ============================================================================
// Signals — high factor (distribution phase) → short, low → long
// ============================================================================
if barstate.isconfirmed
    if factor > signal_ma + i_shortThresh
        if strategy.position_size > 0
            strategy.close("Long")
        strategy.entry("Short", strategy.short)
    else if factor < signal_ma - i_longThresh
        if strategy.position_size < 0
            strategy.close("Short")
        strategy.entry("Long", strategy.long)

// ============================================================================
// Visualization
// ============================================================================
plot(factor,    "Factor (Ideal Amp)", color=color.new(color.orange, 0), display=display.pane)
plot(signal_ma, "Signal MA",          color=color.new(color.blue, 0),   display=display.pane)
hline(0, "Zero", color=color.gray, linestyle=hline.style_dotted, display=display.pane)
