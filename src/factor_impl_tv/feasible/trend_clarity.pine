//@version=6
strategy("Trend Clarity (TREND_CLARITY)", overlay=true,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100,
     fill_orders_on_standard_ohlc=true)

// ============================================================================
// Inputs
// ============================================================================
T = input.int(20, "R-Squared Lookback", minval=5)
rank_period = input.int(120, "Ranking Period", minval=20)
signal_thresh = input.float(0.7, "Signal Threshold (Percentile)", minval=0.0, maxval=1.0)

// ============================================================================
// Calculations: R² of close vs time (bar index) over rolling window
// ============================================================================
var float r_squared = na
var float slope = na

if barstate.isconfirmed
    float sum_x = 0.0
    float sum_y = 0.0
    float sum_xy = 0.0
    float sum_x2 = 0.0
    float sum_y2 = 0.0

    for i = 0 to T - 1
        float x = float(T - 1 - i)  // time index: 0 = oldest, T-1 = newest
        float y = close[i]
        sum_x += x
        sum_y += y
        sum_xy += x * y
        sum_x2 += x * x
        sum_y2 += y * y

    float n = float(T)
    float denom_x = n * sum_x2 - sum_x * sum_x
    float denom_y = n * sum_y2 - sum_y * sum_y
    float denom = denom_x * denom_y

    if denom > 0
        float numerator = n * sum_xy - sum_x * sum_y
        float r = numerator / math.sqrt(denom)
        r_squared := r * r
        slope := numerator / denom_x
    else
        r_squared := 0.0
        slope := 0.0

// Direction-adjusted factor: positive r2 if uptrend, negative r2 if downtrend
factor = slope > 0 ? r_squared : -r_squared

// Rolling percentile approximation
factor_rank = ta.percentrank(factor, rank_period) / 100.0

// ============================================================================
// Signal Logic
// Signal: r_squared high + slope > 0 -> long (strong uptrend)
//         r_squared high + slope < 0 -> short (strong downtrend)
// ============================================================================
if barstate.isconfirmed
    if factor_rank > signal_thresh and strategy.position_size <= 0
        strategy.entry("Long", strategy.long)
    else if factor_rank < (1.0 - signal_thresh) and strategy.position_size >= 0
        strategy.entry("Short", strategy.short)

// ============================================================================
// Visualization
// ============================================================================
plot(r_squared, "R-Squared", color=color.new(color.green, 0), display=display.pane)
plot(factor, "Direction-Adjusted R²", color=color.new(color.orange, 0), display=display.pane)
plot(factor_rank, "Factor Rank", color=color.new(color.blue, 0), display=display.pane)
hline(0.5, "Midline", color=color.gray, linestyle=hline.style_dotted, display=display.pane)
