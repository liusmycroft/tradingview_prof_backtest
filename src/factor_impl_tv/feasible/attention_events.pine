//@version=6
strategy("Attention Events (ATTENTION_EVENTS)", overlay=true,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100,
     fill_orders_on_standard_ohlc=true)

// ── Inputs ──────────────────────────────────────────────────────────────────
i_limitPct    = input.float(0.10, "Limit up/down percentage",  minval=0.01, step=0.01, tooltip="0.10 = 10% for A-share main board; use 0.20 for ChiNext/STAR")
i_window      = input.int(20,     "Lookback window",           minval=1)
i_upperThresh = input.float(2.0,  "Upper threshold (short)",   step=0.5)
i_lowerThresh = input.float(0.0,  "Lower threshold (long)",    step=0.5)

// ── Calculations ────────────────────────────────────────────────────────────
prev_close = close[1]

// Detect limit-up and limit-down events
limit_up   = prev_close > 0 and close >= prev_close * (1.0 + i_limitPct - 0.001) ? 1.0 : 0.0
limit_down = prev_close > 0 and close <= prev_close * (1.0 - i_limitPct + 0.001) ? 1.0 : 0.0

// Rolling count of limit events over window
limit_up_count   = math.round(ta.sma(limit_up, i_window) * i_window)
limit_down_count = math.round(ta.sma(limit_down, i_window) * i_window)

// Total attention events
EVENTS = limit_up_count + limit_down_count

// ── Signals (confirmed bars only) ───────────────────────────────────────────
if barstate.isconfirmed
    if EVENTS > i_upperThresh
        strategy.entry("Short", strategy.short)
    else if EVENTS <= i_lowerThresh
        strategy.entry("Long", strategy.long)

// ── Visualization ───────────────────────────────────────────────────────────
plot(EVENTS,         "EVENTS",       color=color.new(color.orange, 0), display=display.pane)
hline(i_upperThresh, "Upper Thresh", color=color.new(color.red, 50),   linestyle=hline.style_dashed)
hline(i_lowerThresh, "Lower Thresh", color=color.new(color.green, 50), linestyle=hline.style_dashed)
