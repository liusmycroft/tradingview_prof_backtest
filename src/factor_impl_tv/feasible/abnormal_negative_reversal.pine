//@version=6
strategy("Abnormal Negative Reversal (AB_NR)", overlay=true,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100,
     fill_orders_on_standard_ohlc=true)

// ── Inputs ──────────────────────────────────────────────────────────────────
i_T           = input.int(20,  "Short-term window (T)",      minval=1)
i_K           = input.int(12,  "Long-term multiplier (K)",   minval=1)
i_upperThresh = input.float(1.5, "Upper threshold (short)",  step=0.1)
i_lowerThresh = input.float(0.5, "Lower threshold (long)",   step=0.1)

// ── Calculations ────────────────────────────────────────────────────────────
// Overnight return: open vs previous close
ret_co = close[1] != 0 ? open / close[1] - 1.0 : 0.0
// Intraday return: close vs open
ret_oc = open != 0 ? close / open - 1.0 : 0.0

// Negative reversal indicator: gap-up open followed by intraday decline
nr_indicator = (ret_co > 0 and ret_oc < 0) ? 1.0 : 0.0

// Short-term negative-reversal frequency
NR = ta.sma(nr_indicator, i_T)

// Long-term mean (K * T bars as proxy for K months)
longWindow = i_K * i_T
NR_mean = ta.sma(NR, longWindow)

// Abnormal negative reversal ratio
AB_NR = NR_mean != 0 ? NR / NR_mean : 0.0

// ── Signals (confirmed bars only) ───────────────────────────────────────────
if barstate.isconfirmed
    if AB_NR > i_upperThresh
        strategy.entry("Short", strategy.short)
    else if AB_NR < i_lowerThresh
        strategy.entry("Long", strategy.long)

// ── Visualization ───────────────────────────────────────────────────────────
plot(AB_NR,        "AB_NR",          color=color.new(color.orange, 0), display=display.pane)
hline(i_upperThresh, "Upper Thresh", color=color.new(color.red, 50),  linestyle=hline.style_dashed)
hline(i_lowerThresh, "Lower Thresh", color=color.new(color.green, 50), linestyle=hline.style_dashed)
hline(1.0,           "Baseline",     color=color.new(color.gray, 70),  linestyle=hline.style_dotted)
