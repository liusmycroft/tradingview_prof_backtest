//@version=6
strategy("Abnormal Volume Daily (ABNVOLD)", overlay=true,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100,
     fill_orders_on_standard_ohlc=true)

// ── Inputs ──────────────────────────────────────────────────────────────────
i_longWin     = input.int(252,  "Long-term volume average window", minval=1)
i_shortWin    = input.int(20,   "Max abnormal volume window",      minval=1)
i_upperThresh = input.float(2.0, "Upper threshold (short)",        step=0.1)
i_lowerThresh = input.float(0.5, "Lower threshold (long)",         step=0.1)

// ── Calculations ────────────────────────────────────────────────────────────
// Long-term average volume (approx 1 year)
vol_mean = ta.sma(volume, i_longWin)

// Abnormal volume ratio: current volume vs long-term mean
abnormal_vol = vol_mean != 0 ? volume / vol_mean : 0.0

// Maximum abnormal volume over short window — captures peak attention
ABNVOLD = ta.highest(abnormal_vol, i_shortWin)

// ── Signals (confirmed bars only) ───────────────────────────────────────────
if barstate.isconfirmed
    if ABNVOLD > i_upperThresh
        strategy.entry("Short", strategy.short)
    else if ABNVOLD < i_lowerThresh
        strategy.entry("Long", strategy.long)

// ── Visualization ───────────────────────────────────────────────────────────
plot(ABNVOLD,        "ABNVOLD",      color=color.new(color.orange, 0), display=display.pane)
hline(i_upperThresh, "Upper Thresh", color=color.new(color.red, 50),   linestyle=hline.style_dashed)
hline(i_lowerThresh, "Lower Thresh", color=color.new(color.green, 50), linestyle=hline.style_dashed)
hline(1.0,           "Normal",       color=color.new(color.gray, 70),  linestyle=hline.style_dotted)
